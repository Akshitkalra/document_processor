# ============================================================================
# Document Processor — backend configuration
# Copy this file to ".env" and fill in your keys.
# ============================================================================

# --- Google Gemini (required for summary + chat) ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=...
# Model used for the final summary and chat answers.
GEMINI_MODEL=gemini-2.5-flash
# Cheaper, faster model used for the per-section "map" summarisation step.
GEMINI_MAP_MODEL=gemini-2.5-flash-lite

# --- Pinecone (required for indexing + retrieval) ---
PINECONE_API_KEY=pc-...
PINECONE_INDEX=document-processor
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Embeddings ---
# Must match the chosen model's output dimension:
#   all-MiniLM-L6-v2 -> 384
#   all-mpnet-base-v2 -> 768
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=64

# --- Chunking ---
CHUNK_TOKENS=500
CHUNK_OVERLAP_TOKENS=75

# --- OCR (Tesseract) ---
OCR_MIN_TEXT_CHARS=50
OCR_DPI=200
TESSERACT_LANG=eng
# Windows users usually need to set this explicitly:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=

# --- Retrieval / chat ---
RETRIEVAL_TOP_K=8
SUMMARY_MAP_CHUNK_CHARS=12000

# --- Runtime ---
DATA_DIR=./data
MAX_UPLOAD_MB=200

# --- CORS (frontend origins) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
